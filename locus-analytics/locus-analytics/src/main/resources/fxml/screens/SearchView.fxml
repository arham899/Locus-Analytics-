<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" alignment="TOP_LEFT" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.locus.ui.controller.screen.SearchController"
      styleClass="terminal-screen-root">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <HBox alignment="BOTTOM_LEFT" spacing="14.0">
        <VBox spacing="4.0">
            <Label text="Property Search &amp; Compare" styleClass="terminal-section-title"/>
            <Label text="Analyze and compare real estate assets against Fair Market Value benchmarks."
                   styleClass="terminal-muted-text" wrapText="true"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Export CSV" styleClass="terminal-outline-button"/>
        <Button text="Save Search" styleClass="terminal-primary-button"/>
    </HBox>

    <VBox spacing="12.0" styleClass="terminal-card">
        <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="18.0"/>
                <ColumnConstraints percentWidth="32.0"/>
                <ColumnConstraints percentWidth="18.0"/>
                <ColumnConstraints percentWidth="32.0"/>
            </columnConstraints>
            <Label text="Search Properties" styleClass="terminal-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField promptText="Enter property name, ID, or keyword..." GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Location" styleClass="terminal-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <ComboBox fx:id="cityComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Property Type" styleClass="terminal-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="propertyTypeComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Locality" styleClass="terminal-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="localityComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Price Range (PKR)" styleClass="terminal-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <HBox spacing="8.0" GridPane.rowIndex="1" GridPane.columnIndex="3">
                <TextField fx:id="minPriceField" promptText="Min"/>
                <TextField fx:id="maxPriceField" promptText="Max"/>
            </HBox>
            <Label text="Area Range (sq.ft.)" styleClass="terminal-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <HBox spacing="8.0" GridPane.rowIndex="2" GridPane.columnIndex="3">
                <TextField fx:id="minAreaField" promptText="Min"/>
                <TextField fx:id="maxAreaField" promptText="Max"/>
            </HBox>
            <Label text="Bedrooms" styleClass="terminal-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="bedroomsComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="Bathrooms" styleClass="terminal-label" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
            <ComboBox fx:id="bathroomsComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
        </GridPane>

        <HBox spacing="10.0">
            <Label text="Active Filters:" styleClass="terminal-muted-text"/>
            <Label text="Location: DHA Karachi" styleClass="terminal-chip"/>
            <Label text="Type: Commercial" styleClass="terminal-chip"/>
            <Button text="Clear All" onAction="#onClearFilters" styleClass="terminal-link-button"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <ProgressIndicator fx:id="loadingIndicator" maxWidth="22.0" maxHeight="22.0" visible="false" managed="false" styleClass="form-loading-indicator"/>
            <Button fx:id="searchButton" text="Search" onAction="#onSearch" styleClass="terminal-primary-button"/>
            <Button fx:id="addToCompareButton" text="Add to Compare" onAction="#onAddToCompare" styleClass="terminal-outline-button"/>
        </HBox>
    </VBox>

    <VBox spacing="8.0" styleClass="terminal-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Search Results" styleClass="terminal-card-title"/>
            <Label text="(1,204 assets)" styleClass="terminal-muted-text"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="≡" styleClass="terminal-outline-button"/>
            <Button text="☰" styleClass="terminal-outline-button"/>
        </HBox>
        <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="Property Name" prefWidth="220.0"/>
                <TableColumn fx:id="localityColumn" text="Location" prefWidth="220.0"/>
                <TableColumn fx:id="priceColumn" text="Price (PKR)" prefWidth="170.0"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="120.0"/>
                <TableColumn fx:id="areaColumn" text="Area" prefWidth="110.0"/>
                <TableColumn fx:id="bedroomsColumn" text="Beds" prefWidth="70.0"/>
                <TableColumn fx:id="bathroomsColumn" text="Baths" prefWidth="70.0"/>
                <TableColumn fx:id="listingDateColumn" text="Listing Date" prefWidth="150.0"/>
                <TableColumn fx:id="cityColumn" text="City" prefWidth="120.0"/>
            </columns>
        </TableView>
        <Label fx:id="emptyStateLabel" text="No properties found. Try broadening your filters (city, price, or area)." styleClass="terminal-muted-text" visible="false" managed="false"/>
        <BorderPane>
            <left>
                <Label fx:id="resultSummaryLabel" text="Showing 1 to 4 of 1,204 entries" styleClass="terminal-muted-text"/>
            </left>
            <right>
                <HBox spacing="6.0">
                    <Button fx:id="previousPageButton" text="Previous" styleClass="terminal-outline-button" onAction="#onPreviousPage"/>
                    <Label fx:id="currentPageLabel" text="Page 1 / 1" styleClass="terminal-muted-text"/>
                    <Button fx:id="nextPageButton" text="Next" styleClass="terminal-outline-button" onAction="#onNextPage"/>
                    <ComboBox fx:id="pageSizeComboBox" promptText="Page Size"/>
                </HBox>
            </right>
        </BorderPane>
    </VBox>

    <Label fx:id="statusLabel" text="Ready." styleClass="terminal-status-label"/>
</VBox>
