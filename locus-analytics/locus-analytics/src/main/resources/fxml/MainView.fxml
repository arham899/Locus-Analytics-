<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.locus.ui.controller.MainController"
            styleClass="terminal-main-root">
    <top>
        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="terminal-topbar">
            <padding>
                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
            </padding>
            <ImageView fx:id="topbarLogoView" fitHeight="34.0" preserveRatio="true" pickOnBounds="true"/>
            <Label text="LOCUS Analytics" styleClass="terminal-topbar-brand" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" styleClass="terminal-topbar-meta" />
            <Label fx:id="roleLabel" styleClass="terminal-topbar-meta" />
            <Button text="Logout" onAction="#onLogout" styleClass="terminal-secondary-button" />
        </HBox>
    </top>

    <left>
        <VBox spacing="6.0" prefWidth="260.0" styleClass="terminal-sidebar">
            <padding>
                <Insets top="14.0" right="10.0" bottom="12.0" left="10.0" />
            </padding>
            <Label text="LOCUS Analytics" styleClass="terminal-sidebar-brand" />
            <Label text="INSTITUTIONAL TERMINAL" styleClass="terminal-sidebar-subtitle" />

            <Button text="NEW ANALYSIS" styleClass="terminal-cta-button" maxWidth="1.7976931348623157E308"/>
            <Pane prefHeight="8.0"/>

            <Button text="DASHBOARD" styleClass="terminal-nav-button" onAction="#onOpenDashboard" maxWidth="1.7976931348623157E308"/>
            <Button text="REPORTING" styleClass="terminal-nav-button" onAction="#onOpenReport" maxWidth="1.7976931348623157E308"/>
            <Button text="SEARCH PROPERTIES" styleClass="terminal-nav-button" onAction="#onOpenSearch" maxWidth="1.7976931348623157E308"/>
            <Button text="COMPARE PROPERTIES" styleClass="terminal-nav-button" onAction="#onOpenCompare" maxWidth="1.7976931348623157E308"/>
            <Button text="RENTAL YIELD" styleClass="terminal-nav-button" onAction="#onOpenRentalYield" maxWidth="1.7976931348623157E308"/>
            <Button text="ROI ANALYSIS" styleClass="terminal-nav-button" onAction="#onOpenRoi" maxWidth="1.7976931348623157E308"/>
            <Button text="PRICE TRENDS" styleClass="terminal-nav-button" onAction="#onOpenPriceTrends" maxWidth="1.7976931348623157E308"/>
            <Button text="HEATMAP" styleClass="terminal-nav-button" onAction="#onOpenHeatmap" maxWidth="1.7976931348623157E308"/>
            <Button text="CLUSTERS" styleClass="terminal-nav-button" onAction="#onOpenClusters" maxWidth="1.7976931348623157E308"/>

            <VBox fx:id="adminSection" spacing="6.0">
                <Button text="SYSTEM SETTINGS" styleClass="terminal-nav-button terminal-nav-button-active" onAction="#onOpenEtl" maxWidth="1.7976931348623157E308"/>
                <Button text="MANAGE LISTINGS" styleClass="terminal-nav-button" onAction="#onOpenListings" maxWidth="1.7976931348623157E308"/>
                <Button text="CONFIGURATION" styleClass="terminal-nav-button" onAction="#onOpenConfig" maxWidth="1.7976931348623157E308"/>
            </VBox>

            <Pane VBox.vgrow="ALWAYS"/>
            <Button text="SUPPORT" styleClass="terminal-nav-button" maxWidth="1.7976931348623157E308"/>
            <Button text="API DOCS" styleClass="terminal-nav-button" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </left>

    <center>
        <VBox fx:id="contentPane" spacing="10.0" alignment="CENTER" styleClass="terminal-content-area">
            <padding>
                <Insets top="28.0" right="28.0" bottom="28.0" left="28.0" />
            </padding>
            <Label text="Main Application Shell" styleClass="terminal-screen-title" />
            <Label fx:id="statusLabel" text="Loading..." styleClass="terminal-status-label" />
        </VBox>
    </center>
</BorderPane>
